{
  "name": "floorplan-library-pwa",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "serve:dist": "vite preview --host 127.0.0.1 --port 4173",
    "crawl": "node scripts/crawler.mjs --config crawler.config.json --out crawler-output/latest-crawl.json",
    "crawl:image-search": "node scripts/image-search-crawler.mjs --config image-search.config.json --out crawler-output/latest-crawl.json --merge-existing",
    "crawl:common-crawl": "node scripts/common-crawl-candidates.mjs --config common-crawl.config.json --out crawler-output/latest-crawl.json --merge-existing",
    "discover:common-crawl-domains": "node scripts/common-crawl-domain-discovery.mjs --config common-crawl.config.json --discovery-file crawler-output/discovered-sources.json --out crawler-output/common-crawl-domains.json",
    "discover:chrome": "node scripts/chrome-search-source-discovery.mjs --config chrome-discovery.config.json --input .tmp/chrome-search-links.txt --discovery-file crawler-output/discovered-sources.json --out crawler-output/chrome-discovered-sources.json --update-common-crawl",
    "discover:prefectures": "node scripts/prefecture-rotation-discovery.mjs --config prefecture-discovery.config.json --state crawler-output/prefecture-discovery-state.json --out .tmp/prefecture-search-batch.json --text-out .tmp/prefecture-search-queries.txt",
    "discover:prefecture-source-config": "node scripts/build-prefecture-source-config.mjs --batch .tmp/prefecture-auto-batch.json --base-config source-discovery.config.json --out .tmp/prefecture-source-discovery.config.json",
    "discover:duckduckgo": "node scripts/duckduckgo-source-discovery.mjs --config source-discovery.config.json --common-crawl-config common-crawl.config.json --out crawler-output/discovered-sources.json --update-common-crawl",
    "discover:sitemaps": "node scripts/sitemap-seed-expander.mjs --common-crawl-config common-crawl.config.json --crawler-config crawler.config.json --discovery-file crawler-output/discovered-sources.json --out crawler-output/discovered-sources.json --write-config",
    "crawl:discovered": "node scripts/build-discovered-crawler-config.mjs --discovery-file crawler-output/discovered-sources.json --base-config crawler.config.json --out crawler-output/discovered-crawler.config.json && node scripts/crawler.mjs --config crawler-output/discovered-crawler.config.json --out .tmp/discovered-live-crawl.json && node scripts/merge-crawl-output.mjs --base crawler-output/latest-crawl.json --incoming .tmp/discovered-live-crawl.json --out crawler-output/latest-crawl.json",
    "filter:ollama": "node scripts/ollama-floorplan-filter.mjs --config ollama-filter.config.json --input crawler-output/latest-crawl.json --out crawler-output/latest-crawl.json",
    "floorplans:backfill": "node scripts/run-backfill-floorplan-growth.mjs",
    "floorplans:daily": "node scripts/run-daily-floorplan-growth.mjs",
    "floorplans:promote": "node scripts/promote-floorplan-candidates.mjs",
    "floorplans:build-public": "node scripts/build-public-floorplans.mjs",
    "floorplans:stats": "node scripts/update-source-stats.mjs",
    "floorplans:validate": "node scripts/validate-floorplan-data.mjs"
  },
  "dependencies": {
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
